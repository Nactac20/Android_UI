<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextAppearance.StockExchange.Headline" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.StockExchange.Title" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.StockExchange.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.StockExchange.Caption" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Widget.StockExchange.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/radius_m</item>
        <item name="cardElevation">3dp</item>
        <item name="cardUseCompatPadding">false</item>
    </style>

    <style name="Widget.StockExchange.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_s</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_s</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_s</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_s</item>
        <item name="boxStrokeColor">?attr/colorPrimary</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

    <style name="Widget.StockExchange.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">@dimen/radius_s</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.StockExchange.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/radius_s</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.StockExchange.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView.Colored">
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="itemRippleColor">@color/surface_muted</item>
        <item name="itemIconSize">24dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

</resources>


